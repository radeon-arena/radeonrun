# Example .env configuration file for halo-vllm-docker
# Copy this file to .env and customize for your environment.
#
# SCAFFOLD: Strix Halo is typically a single-node APU mini-PC, so the
# multi-node cluster fields are kept for structural parity but are TODO /
# may not apply.

# Cluster configuration (TODO: confirm whether multi-node is in scope for Halo)
# CLUSTER_NODES: Comma-separated list of node IPs (first node is the head node)
CLUSTER_NODES="192.168.177.11,192.168.177.12"

# ETH_IF: Ethernet interface name (optional, auto-detected if not specified)
ETH_IF="enp1s0f1np1"

# IB_IF: high-speed interconnect interface (optional, auto-detected)
# TODO: Strix Halo interconnect differs from DGX Spark ConnectX-7; revisit.
IB_IF=""

# LOCAL_IP: Local IP address (optional, auto-detected if not specified)
LOCAL_IP="192.168.177.11"

# MASTER_PORT: Port for cluster coordination (default: 29501)
MASTER_PORT="29501"

# CONTAINER_NAME: Container name (default: halo_vllm_node)
# Note: This is a configuration variable, NOT passed as env var to container
CONTAINER_NAME="halo_vllm_node"

# Container environment variables
# Any variable starting with CONTAINER_ (except CONTAINER_NAME) is converted to
# a -e flag for `docker run`. Example: CONTAINER_FOO=bar -> -e FOO=bar
CONTAINER_HF_TOKEN="your_huggingface_token_here"
# TODO(ROCm): set the right gfx override / RCCL knobs after hardware testing.
# CONTAINER_HSA_OVERRIDE_GFX_VERSION="11.5.1"
# CONTAINER_RCCL_DEBUG="INFO"

# COPY_HOSTS: Comma-separated list of hosts for build-and-copy.sh (optional)
COPY_HOSTS=""

# Additional container environment variables
# CONTAINER_MAX_JOBS="16"
# CONTAINER_HIP_VISIBLE_DEVICES="0"
