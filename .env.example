# Example .env configuration file for radeonrun
# Copy this file to .env and customize for your environment.
#
# Strix Halo is a single-GPU APU; these are the knobs that actually matter for
# a single-node setup. (No multi-node / cluster config — see the README.)

# IMAGE: container image to run (default: halo-vllm-node)
IMAGE="halo-vllm-node"

# CONTAINER: container name (default: halo_vllm_node)
CONTAINER="halo_vllm_node"

# MODELS_DIR: host directory mounted into the container at /models
MODELS_DIR="/models"

# HF_HOME: host HuggingFace cache (mounted to /root/.cache/huggingface)
# HF_HOME="$HOME/.cache/huggingface"

# HF token for gated/private model downloads (used by hf-download.sh)
HF_TOKEN="your_huggingface_token_here"

# HIP_VISIBLE_DEVICES: which GPU index to expose (usually 0 on a Halo box;
# set this if the node has more than one render device)
# HIP_VISIBLE_DEVICES="0"

# HSA_OVERRIDE_GFX_VERSION: only set if ROCm misidentifies the arch. The
# official gfx1151 base usually detects gfx1151 (RDNA 3.5) correctly, so leave
# this unset unless you hit an arch-detection error.
# HSA_OVERRIDE_GFX_VERSION="11.5.1"
