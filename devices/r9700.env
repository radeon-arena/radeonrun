# Device profile: AMD Radeon AI PRO R9700 (RDNA4 dGPU)
#
# Arch:    gfx1201 (RDNA4; gfx1200 is an older compatibility label)
# Status:  PLACEHOLDER — base images are NOT pinned yet. RDNA4 (gfx1201) needs a
#          ROCm 7.x build with gfx1201 support (TheRock / kyuz0 line). Fill in
#          VLLM_BASE and ROCM_VERSION with a verified RDNA4 base before building;
#          build.sh will refuse to build vllm if VLLM_BASE is empty.

DEVICE=r9700
GFX=gfx1201

# vLLM: set to a gfx1201-capable ROCm vLLM base (e.g. a TheRock/kyuz0 RDNA4
# build). Left empty on purpose so an unverified image is never built silently.
VLLM_BASE=

# llama.cpp: ROCm dev base with gfx1201 support. Verify before relying on it.
ROCM_VERSION=7.13
