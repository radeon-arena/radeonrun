# Device profile: AMD Radeon AI PRO R9700 (RDNA4 dGPU)
#
# Arch:    gfx1201 (RDNA4; gfx1200 is an older compatibility label)
# Status: runtime uses digest-pinned InferStation gfx1201 images declared by the
#         R9700 launch specs. Local vLLM builds remain disabled here until
#         RadeonRun owns a separately verified base image.

DEVICE=r9700
GFX=gfx1201

# vLLM: intentionally empty. R9700 matrices use an explicit external runtime;
# build.sh must still refuse an accidental local vLLM build.
VLLM_BASE=

# llama.cpp: ROCm dev base with gfx1201 support. Verify before relying on it.
ROCM_VERSION=7.13
