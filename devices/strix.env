# Device profile: AMD Strix Halo (Radeon 8060S iGPU)
#
# Arch:    gfx1151 (RDNA 3.5 APU)
# Status:  VERIFIED — this is the device the recipes were measured on
#          (InferStation halo5 / halo6 fleet).
#
# Sourced by build.sh. GFX is passed to PYTORCH_ROCM_ARCH (vLLM) /
# ROCM_DOCKER_ARCH (llama.cpp); the *_BASE values pick the right base image.

DEVICE=strix
GFX=gfx1151

# vLLM: AMD's official gfx1151 base (ROCm 7.13 / PyTorch 2.10 / py3.13).
# Carries gfx1151-tuned kernels; the wheel we build overwrites its vLLM 0.19.1.
VLLM_BASE=rocm/vllm:rocm7.13.0_gfx1151_ubuntu24.04_py3.13_pytorch_2.10.0_vllm_0.19.1

# llama.cpp: ROCm dev base. gfx1151 needs ROCm >= 7.2.x (7.0 does not support it).
ROCM_VERSION=7.2.1
