# Device profile: AMD Radeon PRO W7900 (RDNA3 dGPU)
#
# Arch:    gfx1100 (RDNA3)
# Status:  UNVERIFIED placeholder — gfx1100 is officially supported by ROCm, so
#          the stock rocm/vllm and rocm/dev bases work, but the recipes here
#          have NOT yet been measured on W7900. Adjust the bases/versions to the
#          ROCm release on your host, then build and verify before publishing.

DEVICE=w7900
GFX=gfx1100

# vLLM: official upstream ROCm vLLM image supports gfx1100 (RDNA3) directly.
# Pin to the tag matching your host's ROCm before building.
VLLM_BASE=rocm/vllm:latest

# llama.cpp: any recent ROCm dev base with gfx1100 (broadly supported).
ROCM_VERSION=7.2.1
